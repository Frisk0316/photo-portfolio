# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=photo-portfolio
R2_PUBLIC_URL=https://photos.yourdomain.com

# PostgreSQL
DATABASE_URL=postgresql://portfolio:localdev@localhost:5432/portfolio

# Backend
JWT_SECRET=change-this-to-a-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this

# Photo processing
THUMBNAIL_HEIGHT=400
MEDIUM_WIDTH=1600
WEBP_QUALITY=82
JPEG_QUALITY=85

# Upload concurrency
UPLOAD_CONCURRENCY=4

# Local photo root (for uploader CLI)
PHOTOS_ROOT_DIR=/path/to/your/photos

# Edited folder names (comma-separated, case-insensitive match)
EDITED_FOLDER_NAMES=調整後 JPG,調整後JPG,Edited JPG,edited

# Folders to skip
SKIP_FOLDER_NAMES=原始 JPG,原始JPG,Raw JPG,raw

# File extensions to skip
SKIP_EXTENSIONS=.arw,.nef,.cr2,.cr3,.raf,.orf,.rw2,.dng

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
